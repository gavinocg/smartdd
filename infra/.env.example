# ─── Base de datos ───────────────────────────────────
DB_USER=smartdd
DB_PASSWORD=smartdd_pass
DB_NAME=smartdd

# ─── Redis ──────────────────────────────────────────
REDIS_PASSWORD=redis_pass

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# ─── Jitsi Meet ────────────────────────────────────
JITSI_DOMAIN=jitsi.smartdd.com
JICOFO_COMPONENT_SECRET=jicofo_secret

# ─── Cloudflare Tunnel ─────────────────────────────
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ─── Firebase Admin SDK (para FCM push) ────────────
# Proporcionar UNO de los siguientes métodos:
# Opción 1: Ruta al archivo serviceAccountKey.json
#   GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-key.json
# Opción 2: JSON completo del service account como variable
#   FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
FCM_PROJECT_ID=smartdd-xxxxx

# ─── Google Play Billing ───────────────────────────
PLAY_LICENSE_KEY=your-google-play-license-key

# ─── Admin inicial ─────────────────────────────────
ADMIN_EMAIL=admin@smartdd.com
ADMIN_PASSWORD=admin-secure-password

# ─── Configuración global ──────────────────────────
DEFAULT_RADIUS_METERS=50
DEFAULT_TIMEOUT_SECONDS=60
NODE_ENV=production
